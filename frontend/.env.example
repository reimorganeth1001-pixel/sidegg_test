# --- App URLs (Next dev uses port 3113; see package.json) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3113

# --- Supabase (X OAuth) — Project Settings → API (NOT the postgres:// DB URL) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# OAuth provider id: use `x` (OAuth 2.0). Legacy dashboard may use `twitter` instead.
NEXT_PUBLIC_SUPABASE_OAUTH_PROVIDER=x

# --- RainbowKit / WalletConnect (free project id: https://cloud.walletconnect.com) ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Backend REST (Express mounts routes at /api; default PORT in backend/.env.example is 4444) ---
NEXT_PUBLIC_SIDEGG_SERVER=http://localhost:4444/api
NEXT_PUBLIC_FETCH_CODESTATUS_API=code/searchCodeAndUpdateStatus
NEXT_PUBLIC_CREAT_USER=user/create
NEXT_PUBLIC_GET_GAME_INFO=game/search
NEXT_PUBLIC_UPDATE_USERNAME=user/update
NEXT_PUBLIC_UPDATE_USER_STATUS=user/updateStatus
NEXT_PUBLIC_PLAYGAME=user/play
NEXT_PUBLIC_FETCH_GAME_ACTIONS=game/actions
NEXT_PUBLIC_FETCH_USER_INFO=user/getUserInfo
NEXT_PUBLIC_FETCH_MESSAGES=chat/getMessages
NEXT_PUBLIC_FETCH_USER_GAME_INFO=user/getUserGameInfo
NEXT_PUBLIC_FETCH_TEAM_SCORE=game/score
NEXT_PUBLIC_FETCH_PERIOD_CLOCK=game/clock-period
NEXT_PUBLIC_FETCH_GAME_INITIAL_DATA=game/initialGame
NEXT_PUBLIC_GAME_STATUS_INTERVAL=5000
NEXT_PUBLIC_FETCH_USRE_GAME_SCORE=user/gamescore
NEXT_PUBLIC_SET_USRE_GAME_SCORE=user/setUserGamePoints
NEXT_PUBLIC_GET_USRE_GAME_DETAIL=user/userGameDetail
NEXT_PUBLIC_GET_USRE_GAME_GET_OR_LOASS_SCORE=user/getGetorLoassGamePointsAndSol
NEXT_PUBLIC_GAME_STATUS=STATUS

# --- Socket.IO (backend default SOCKET_PORT=8888; must match server transport URL) ---
NEXT_PUBLIC_WEBSOCKET_URI=http://localhost:8888
NEXT_PUBLIC_WEBSOCKET_SEND_NEW_MESSAGE=sendMessage
NEXT_PUBLIC_WEBSOCKET_FETCH_MESSAGES=fetchMessages
NEXT_PUBLIC_WEBSOCKET_NEW_MESSAGE=newMessage
NEXT_PUBLIC_WEBSOCKET_CHAT_HISTORY=chatHistory

# --- Client-side JWT helper (exposed in browser; use only for local dev / demos) ---
NEXT_PUBLIC_JWT_SECRET=change_me_local_dev_only
